# Copy to /opt/owl/.env on the Proxmox Docker VM.
# Do not commit real secrets.

OWL_IMAGE=ghcr.io/consigcody94/asos-tools-ui:latest
OWL_HOSTNAME=owl.local
NEXT_PUBLIC_SITE_URL=https://owl.yourdomain.com

POSTGRES_DB=owl
POSTGRES_USER=owl
POSTGRES_PASSWORD=replace-with-long-random-password

REDIS_URL=redis://redis:6379
DATABASE_URL=postgres://owl:replace-with-long-random-password@postgres:5432/owl

# Optional, depending on enabled phases.
APPLICATIONINSIGHTS_CONNECTION_STRING=
OPENAI_API_KEY=
AI_BRIEF_MODEL=gpt-4o
